<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tasks_widget_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✅ المهام اليومية"
            android:textColor="#A5B4FC"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tasks_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 متبقية"
            android:textColor="#818CF8"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider Line -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F1F3A"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Task Item 1 -->
    <LinearLayout
        android:id="@+id/task_item_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">

        <TextView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/task_bullet_1" />

        <TextView
            android:id="@+id/task_title_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E8E8FF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Task Item 2 -->
    <LinearLayout
        android:id="@+id/task_item_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/task_bullet_2" />

        <TextView
            android:id="@+id/task_title_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#C4C4E8"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Task Item 3 -->
    <LinearLayout
        android:id="@+id/task_item_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/task_bullet_3" />

        <TextView
            android:id="@+id/task_title_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#A0A0C8"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Empty State -->
    <TextView
        android:id="@+id/tasks_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="🎉 أحسنت! أكملت جميع المهام"
        android:textColor="#6B7280"
        android:textSize="11sp"
        android:layout_marginTop="10dp"
        android:visibility="visible" />

    <!-- Spacer -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Progress Row -->
    <LinearLayout
        android:id="@+id/tasks_progress_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/tasks_progress"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:indeterminate="false"
            android:progressDrawable="@drawable/tasks_progress_bar" />

        <TextView
            android:id="@+id/tasks_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#818CF8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
