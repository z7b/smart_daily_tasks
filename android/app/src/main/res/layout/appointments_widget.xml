<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/appointments_widget_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏥 مواعيد الطبيب"
            android:textColor="#A7F3D0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/appt_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="قريباً"
            android:textColor="#34D399"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Divider Line -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0A2A1E"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/appt_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="📅 لا توجد مواعيد قادمة"
        android:textColor="#4B7A66"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Appointment Content -->
    <LinearLayout
        android:id="@+id/appt_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Doctor Name & Avatar Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar circle -->
            <TextView
                android:id="@+id/appt_avatar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_green_bg"
                android:gravity="center"
                android:text="د"
                android:textColor="#34D399"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/appt_doctor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="د. سليمان السعدون"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/appt_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="موعد قادم"
                    android:textColor="#6EE7B7"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Spacer -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Info Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Time Row -->
            <LinearLayout
                android:id="@+id/appt_time_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/appt_card_bg"
                android:padding="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/appt_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#A7F3D0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Spacing -->
            <FrameLayout
                android:id="@+id/appt_spacer"
                android:layout_width="6dp"
                android:layout_height="match_parent" />

            <!-- Location Row -->
            <LinearLayout
                android:id="@+id/appt_location_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/appt_card_bg"
                android:padding="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/appt_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#A7F3D0"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
