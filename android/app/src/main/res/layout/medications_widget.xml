<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/medications_widget_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💊 علاجاتي"
            android:textColor="#BFDBFE"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/meds_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textColor="#60A5FA"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider Line -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0A1A3A"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/meds_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="لا توجد علاجات اليوم"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/meds_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0"
        android:indeterminate="false"
        android:progressDrawable="@drawable/meds_progress_bar"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

    <!-- Stats Cards Row -->
    <LinearLayout
        android:id="@+id/meds_stats_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <!-- Taken Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/meds_card_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center">

            <TextView
                android:id="@+id/meds_taken_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#34D399"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تم تناوله"
                android:textColor="#6EE7B7"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- Spacer -->
        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="match_parent" />

        <!-- Remaining Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/meds_card_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center">

            <TextView
                android:id="@+id/meds_remaining_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#F87171"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="متبقي"
                android:textColor="#FCA5A5"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Spacer to push next section to bottom -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Next Dose Card -->
    <LinearLayout
        android:id="@+id/meds_next_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/meds_card_bg"
        android:padding="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ الجرعة القادمة"
                android:textColor="#60A5FA"
                android:textSize="8sp" />

            <TextView
                android:id="@+id/meds_next_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/meds_next_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#93C5FD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
